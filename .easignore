# EAS Build ignore list. Overrides .gitignore for EAS upload only.
# git still ignores everything below — we just want EAS to include
# google-services.json so the Google Services gradle plugin can read
# it during the cloud build.

.claude/
.expo/web/
node_modules
android/build/
android/app/build/
android/.gradle/
android/app/.cxx/
ble_log.txt
.env
.env.local
.vscode/
.expo/devices.json

app-log.txt
*.logcat

# Signing credentials - NEVER commit
*.jks
*.pem
*.keystore

# Build artifacts. Use a contents glob (not bare directory) so the
# Play-verification file below can override via negation; bare
# `dir/` excludes the directory itself and prevents re-inclusion of
# anything inside it.
android/app/src/main/assets/*
!android/app/src/main/assets/adi-registration.properties

# Firebase / FCM (sensitive)
google-services.json
android/app/google-services.json
*-firebase-adminsdk-*.json
firebase-debug.log
.firebase/

# EAS Build needs these even though git ignores them. Negations must
# come AFTER the matching ignore patterns to take effect. The Firebase
# admin SDK service account stays ignored — that one is uploaded to
# EAS as a credential, not bundled into the build.
!google-services.json
!android/app/google-services.json
